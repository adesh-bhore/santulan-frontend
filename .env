# TransitPulse Frontend Environment Configuration
# Copy from .env.example and customize for your environment

# API Configuration
VITE_API_URL=http://51.21.226.149:8000/api
VITE_USE_MOCK=false

# Auto-refresh intervals (milliseconds)
VITE_REFRESH_DASHBOARD=30000
VITE_REFRESH_ROUTES=30000
VITE_REFRESH_ALERTS=10000
VITE_REFRESH_ACTIVITIES=30000

# Feature Flags
VITE_ENABLE_LIVE_TRACKING=false
VITE_ENABLE_NOTIFICATIONS=false

# Development
VITE_DEBUG_MODE=false
